# Visual-regression baselines are platform-keyed and currently
# unseeded for the CI Linux runner (the visual job runs with
# `--ignore-snapshots`). Local darwin baselines live here while
# the workflow is bedded in; once Linux seeds land, this rule
# narrows to the platforms we don't track.
tests/visual/__screenshots__/

# Tauri / app data
*.app
*.dmg
*.exe
*.msi

# Temp / scratch
tmp/
*.tmp
.scratch/

# Agent-tooling config is maintainer-local; not tracked in the public repo.
.claude/

# Thalyn runtime data (created at runtime; never committed)
runs/
*.db
*.db-shm
*.db-wal

# In-progress agent state (transient; never committed)
STUCK.md

# Local working notebook (per-developer; never committed)
PROGRESS.md

# Project planning docs are maintained outside the public repository
# (per ADR-0031). They live on the maintainer's local filesystem at
# the same paths but are never tracked here.
01-requirements.md
02-architecture.md
03-prompt-plan.md
docs/archive/
